@article{10.1145/3720426,
author = {Shi, Jessica and Torczon, Cassia and Goldstein, Harrison and Pierce, Benjamin C. and Head, Andrew},
title = {QED in Context: An Observation Study of Proof Assistant Users},
year = {2025},
issue_date = {April 2025},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {9},
number = {OOPSLA1},
url = {https://doi.org/10.1145/3720426},
doi = {10.1145/3720426},
abstract = {Interactive theorem provers, or proof assistants, are important tools across many areas of computer science and mathematics, but even experts find them challenging to use effectively. To improve their design, we need a deeper, user-centric understanding of proof assistant usage.    We present the results of an observation study of proof assistant users. We use contextual inquiry methodology, observing 30 participants doing their everyday work in Rocq and Lean. We qualitatively analyze their experiences to surface four observations: that proof writers iterate on their proofs by reacting to and incorporating feedback from the proof assistant; that proof progress often involves challenging conversations with the proof assistant; that proofs are constructed in consultation with a wide array of external resources; and that proof writers are guided by design considerations that go beyond "getting to QED." Our documentation of these themes clarifies what proof assistant usage looks like currently and identifies potential opportunities that researchers should consider when working to improve the usability of proof assistants.},
journal = {Proc. ACM Program. Lang.},
month = apr,
articleno = {92},
numpages = {27},
keywords = {Contextual Inquiry, Human Factors, Proof Assistants}
}

