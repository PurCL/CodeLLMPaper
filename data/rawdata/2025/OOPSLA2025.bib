@article{10.1145/3763164,
author = {Viola, Cosmo and Fan, Max and Ringer, Talia},
title = {Proof Repair across Quotient Type Equivalences},
year = {2025},
issue_date = {October 2025},
publisher = {Association for Computing Machinery},
