@article{10.1145/3763146,
author = {Won, Jaeyeon and Ahrens, Willow and Collin, Teodoro Fields and Emer, Joel S. and Amarasinghe, Saman},
title = {The Continuous Tensor Abstraction: Where Indices Are Real},
year = {2025},
issue_date = {October 2025},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {9},
number = {OOPSLA2},
url = {https://doi.org/10.1145/3763146},
doi = {10.1145/3763146},
abstract = {This paper introduces the continuous tensor abstraction, allowing indices to take real-number values (e.g., A[3.14]). It also presents continuous tensor algebra expressions, such as Cx,y = Ax,y ∗ Bx,y, where indices are defined over a continuous domain. This work expands the traditional tensor model to include continuous tensors. Our implementation supports piecewise-constant tensors, on which infinite domains can be processed in finite time. We also introduce a new tensor format for efficient storage and a code generation technique for automatic kernel generation. For the first time, our abstraction expresses domains like computational geometry and computer graphics in the language of tensor programming. Our approach demonstrates competitive or better performance to hand-optimized kernels in leading libraries across diverse applications. Compared to hand-implemented libraries on a CPU, our compiler-based implementation achieves an average speedup of 9.20\texttimes{} on 2D radius search with ∼60\texttimes{} fewer lines of code (LoC), 1.22\texttimes{} on genomic interval overlapping queries (with ∼18\texttimes{} LoC saving), and 1.69\texttimes{} on trilinear interpolation in Neural Radiance Field (with ∼6\texttimes{} LoC saving).},
journal = {Proc. ACM Program. Lang.},
month = oct,
articleno = {368},
numpages = {29},
keywords = {Domain Specific Language, Sparse Tensor Compiler}
}

@article{10.1145/3763147,
author = {Berger, Ryan and Briles, Mitch and Boushehrinejad Moradi, Nader and Coughlin, Nicholas and Lam, Kait and Lopes, Nuno P. and Mada, Stefan and Tirpankar, Tanmay and Regehr, John},
title = {Translation Validation for LLVM’s AArch64 Backend},
year = {2025},
issue_date = {October 2025},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {9},
number = {OOPSLA2},
url = {https://doi.org/10.1145/3763147},
doi = {10.1145/3763147},
abstract = {LLVM's backends translate its intermediate representation (IR) to   assembly or object code. Alongside register allocation and   instruction selection, these backends contain many analogues of   components traditionally associated with compiler middle ends:   dataflow analyses, common subexpression elimination, loop invariant   code motion, and a first-class IR -- MIR, the "machine IR." In   effect, this kind of compiler backend is a highly optimizing compiler   in its own right, with all of the correctness hazards entailed by a   million lines of intricate C++. As a step towards gaining confidence   in the correctness of work done by LLVM backends, we have created   arm-tv, which formally verifies translations between LLVM IR and   AArch64 (64-bit ARM) code. Ours is not the first translation   validation work for LLVM, but we have advanced the state of the art   along multiple fronts: arm-tv is a checking validator that enforces   numerous ABI rules; we have extended Alive2 (which we reuse as a   verification backend) to deal with unstructured mixes of pointers and   integers that are typical of assembly code; we investigate the   tradeoffs between hand-written AArch64 semantics and those derived   mechanically from ARM's published formal semantics; and, we have used   arm-tv to discover 45 previously unknown miscompilation bugs in this   LLVM backend, most of which are now fixed in upstream LLVM.},
journal = {Proc. ACM Program. Lang.},
month = oct,
articleno = {369},
numpages = {26},
keywords = {application binary interface, lifting, semantics, translation validation}
}

