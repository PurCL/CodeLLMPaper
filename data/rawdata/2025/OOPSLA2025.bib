@article{10.1145/3763150,
author = {Tzour-Shaday, Saar and Drachsler-Cohen, Dana},
title = {Mini-Batch Robustness Verification of Deep Neural Networks},
year = {2025},
issue_date = {October 2025},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {9},
number = {OOPSLA2},
url = {https://doi.org/10.1145/3763150},
doi = {10.1145/3763150},
abstract = {Neural network image classifiers are ubiquitous in many safety-critical applications. However, they are susceptible to adversarial attacks. To understand their robustness to attacks, many local robustness verifiers have been proposed to analyze є-balls of inputs. Yet, existing verifiers introduce a long analysis time or lose too much precision, making them less effective for a large set of inputs. In this work, we propose a new approach to local robustness: group local robustness verification. The key idea is to leverage the similarity of the network computations of certain є-balls to reduce the overall analysis time. We propose BaVerLy, a sound and complete verifier that boosts the local robustness verification of a set of є-balls by dynamically constructing and verifying mini-batches. BaVerLy adaptively identifies successful mini-batch sizes, accordingly constructs mini-batches of є-balls that have similar network computations, and verifies them jointly. If a mini-batch is verified, all its є-balls are proven robust. Otherwise, one є-ball is suspected as not being robust, guiding the refinement. BaVerLy leverages the analysis results to expedite the analysis of that є-ball as well as the analysis of the mini-batch with the other є-balls. We evaluate BaVerLy on fully connected and convolutional networks for MNIST and CIFAR-10. Results show that BaVerLy scales the common one by one verification by 2.3x on average and up to 4.1x, in which case it reduces the total analysis time from 24 hours to 6 hours.},
journal = {Proc. ACM Program. Lang.},
month = oct,
articleno = {372},
numpages = {29},
keywords = {Local Robustness, Neural Network Verification}
}

@software{10.5281/zenodo.16892960,
author = {Tzour-Shaday, Saar and Drachsler-Cohen, Dana},
title = {BaVerLy},
year = {2025},
publisher = {Association for Computing Machinery},
url = {https://doi.org/10.5281/zenodo.16892960},
abstract = {
    A framework for efficient group verification of neural network local
robustness. BaVerLy enhances scalability and precision in verifying
large sets of inputs by extending the MIPVerify module, a package for
evaluating the robustness of neural networks using Mixed Integer
Programming (MIP). BaVerLy expedites the end-to-end verification of a
Deep Neural Network (DNN) for local robustness, given an perturbation
bound and a set of inputs, by integrating the following features: 1.
Efficient Network Splitting: BaVerLy can split the DNN at an
intermediate layer, computing input bounds at that point. This is
effective because input representations at deeper layers are often more
similar, allowing for more precise merging and reduced analysis time.
You can either specify a split layer or let BaVerLy automatically
determine the optimal one by sampling different candidate layers. 2.
Hierarchical Sample Clustering: BaVerLy organizes inputs into a
dendrogram based on their similarity, using a chosen distance metric.
This hierarchical structure enables dynamic clustering, quickly
identifying and extracting groups of similar inputs for batch
verification. 3. Adaptive Batch Size Reinforcement Learning: To select
the most efficient group of inputs for verification, BaVerLy employs a
Multi-Armed Bandit (MAB) approach powered by a Thompson Sampling
algorithm. This system learns the optimal batch size on the fly by
observing the “velocity” (verification speed) of different sizes,
balancing exploring new options and exploiting previously successful
ones. 4. Precise MILP Disjunction Encoding: Instead of simply
approximating input bounds when merging them for batch verification,
BaVerLy uses Mixed Integer Linear Programming (MILP) “OR” constraints.
This more precise encoding helps prevent spurious counterexamples and
speeds up the overall analysis by maintaining accuracy during the
merging process.

},
keywords = {Adversarial Attacks, Deep Learning, Group Local Robustness Verification, Local Robustness, MILP, MIxed Integer Linear Programming, Neural Network Verification}
}

@article{10.1145/3763151,
author = {L\"{o}\"{o}w, Andreas and Park, Seung Hoon and Nantes-Sobrinho, Daniele and Ayoun, Sacha-\'{E}lie and Sj\"{o}stedt, Opale and Gardner, Philippa},
title = {Compositional Symbolic Execution for the Next 700 Memory Models},
year = {2025},
issue_date = {October 2025},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {9},
number = {OOPSLA2},
url = {https://doi.org/10.1145/3763151},
doi = {10.1145/3763151},
abstract = {Multiple successful compositional symbolic execution (CSE) tools and platforms exploit separation logic (SL) for compositional verification and/or incorrectness separation logic (ISL) for compositional bug-finding, including VeriFast, Viper, Gillian, CN, and Infer-Pulse. Previous work on the Gillian platform, the only CSE platform that is parametric on the memory model, meaning that it can be instantiated to different memory models, suggests that the ability to use custom memory models allows for more flexibility in supporting analysis of a wide range of programming languages, for implementing custom automation, and for improving performance. However, the literature lacks a satisfactory formal foundation for memory-model-parametric CSE platforms.    In this paper, inspired by Gillian, we provide a new formal foundation for memory-model-parametric CSE platforms. Our foundation advances the state of the art in four ways. First, we mechanise our foundation (in the interactive theorem prover Rocq). Second, we validate our foundation by instantiating it to a broad range of memory models, including models for C and CHERI. Third, whereas previous memory-model-parametric work has only covered SL analyses, we cover both SL and ISL analyses. Fourth, our foundation is based on standard definitions of SL and ISL (including definitions of function specification validity, to ensure sound interoperation with other tools and platforms also based on standard definitions).},
journal = {Proc. ACM Program. Lang.},
month = oct,
articleno = {373},
numpages = {28},
keywords = {incorrectness logic, memory model, separation logic, symbolic execution}
}

