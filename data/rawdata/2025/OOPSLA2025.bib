@article{10.1145/3763067,
author = {Lee, Jay and Ahn, Joongwon and Yi, Kwangkeun},
title = {React-tRace: A Semantics for Understanding React Hooks: An Operational Semantics and a Visualizer for Clarifying React Hooks},
